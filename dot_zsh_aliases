# ===========================
# 📂 DIRECTORY LISTING ALIASES
# ===========================
# Traditional ls (original command)
alias ls="ls -G"           # macOS with colors

alias ll="ls -lah"         # Long format, human-readable sizes, show hidden files
alias la="ls -A"           # List all except `.` and `..`
alias l="ls -CF"           # Compact view with file type indicators

# Modern lsd aliases (lls = lsd ls)
if command -v lsd &> /dev/null; then
  alias lls='lsd'            # Modern ls replacement
  alias lll='lsd -l'         # Long format
  alias lla='lsd -la'        # Long format with hidden files
  alias llt='lsd --tree'     # Tree view
else
  # Fallback if lsd is not available
  alias lls='ls'
  alias lll='ll'
  alias lla='la'
  alias llt='tree 2>/dev/null || ls -R'
fi

