# ===========================
# golang
# Make 'go test' pretty if richgo is available; don't break other subcommands
# ===========================
go() {
  if [[ "$1" == "test" ]] && command -v richgo >/dev/null 2>&1; then
    command richgo "$@"
  else
    command go "$@"
  fi
}
