# ============================================================================
# Kitty Terminal Configuration — thin host for Zellij
# ============================================================================

# ============================================================================
# Font
# ============================================================================
font_family      family="JetBrainsMono Nerd Font Mono"
bold_font        family="JetBrainsMono Nerd Font Mono" style=Bold
font_size        15.0
font_features    JetBrainsMonoNerdFontMono-Regular +zero +cv14
text_composition_strategy 1.8 30
text_fg_override_threshold 0
modify_font cell_height 125%
modify_font cell_width 101%

# ============================================================================
# Cursor
# ============================================================================
cursor_shape beam
cursor_blink_interval 0.5
cursor_stop_blinking_after 10.0
cursor_trail 1
cursor_trail_decay 0.1 0.2

# ============================================================================
# Mouse
# ============================================================================
mouse_hide_wait 3.0
copy_on_select yes
strip_trailing_spaces smart

# ============================================================================
# Clipboard
# ============================================================================
clipboard_control write-clipboard write-primary read-clipboard read-primary
clipboard_max_size 64

# ============================================================================
# Performance
# ============================================================================
repaint_delay 8
input_delay 2
update_check_interval 0

# ============================================================================
# Bell
# ============================================================================
enable_audio_bell no
visual_bell_duration 0.1

# ============================================================================
# Window
# ============================================================================
remember_window_position yes

# ============================================================================
# Shell — launches Zellij as the default program
# ============================================================================
shell /Users/ab/.config/kitty/launch-zellij.sh
shell_integration enabled no-sudo
allow_remote_control socket-only
listen_on unix:/tmp/kitty-{kitty_pid}
term xterm-256color

# ============================================================================
# Includes
# ============================================================================
include macos-shortcuts.conf
include current-theme.conf