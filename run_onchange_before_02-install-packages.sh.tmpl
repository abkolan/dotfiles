#!/bin/bash
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
# Brewfile hash: {{ include "Brewfile" | sha256sum }}

# Bootstrap Homebrew PATH
if [[ -x "/opt/homebrew/bin/brew" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x "/usr/local/bin/brew" ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

if ! command -v brew &>/dev/null; then
  echo "ERROR: Homebrew not found."
  exit 1
fi

echo "Installing packages from Brewfile..."
brew bundle --file=/dev/stdin <<'BREWFILE'
{{ include "Brewfile" }}
BREWFILE

echo "Brew bundle complete"
{{ else if eq .chezmoi.os "linux" -}}
# Aptfile hash: {{ include "Aptfile" | sha256sum }}

echo "Installing packages via apt..."
sudo apt-get update -qq

# Read package list, skipping blank lines and comments
PACKAGES=$(cat <<'APTFILE'
{{ include "Aptfile" }}
APTFILE
)

PACKAGES=$(printf '%s\n' "$PACKAGES" | grep -vE '^\s*(#|$)' || true)
if [[ -n "$PACKAGES" ]]; then
  echo "$PACKAGES" | xargs sudo apt-get install -y -qq
fi

echo "Apt packages installed"

# Snap packages (not available in apt)
if command -v snap &>/dev/null; then
  echo "Installing snap packages..."
  sudo snap install zellij --classic || true
  echo "Snap packages installed"
fi
{{ end -}}
