{{- $email := promptStringOnce . "email" "Git email address" -}}
{{- $name := promptStringOnce . "name" "Git user name" -}}
{{- $workspacePath := promptStringOnce . "workspacePath" "Workspace path (default: ~/repos)" -}}
{{- $abkolanEmail := promptStringOnce . "abkolanEmail" "Git email for the abkolan GitHub account" -}}
{{- $abhilastEmail := promptStringOnce . "abhilastEmail" "Git email for the abhilast GitHub account" -}}

[data]
  email = {{ $email | quote }}
  name = {{ $name | quote }}
  workspacePath = {{ $workspacePath | quote }}
  abkolanEmail = {{ $abkolanEmail | quote }}
  abhilastEmail = {{ $abhilastEmail | quote }}
